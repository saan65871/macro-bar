<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>FX & Oil Dashboard</title>
  <style>
    body {
      margin: 0;
      padding: 14px;
      background: #0f1115;
      font-family: Arial, sans-serif;
      color: #e5e7eb;
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(420px, 1fr));
      gap: 14px;
    }
    .card {
      background: #161a22;
      border: 1px solid #262b36;
      border-radius: 12px;
      padding: 10px;
      box-sizing: border-box;
    }
    .label {
      font-size: 13px;
      font-weight: 700;
      margin-bottom: 10px;
      color: #9ca3af;
      letter-spacing: 0.3px;
    }
  </style>
</head>
<body>
  <div class="grid">

    <div class="card">
      <div class="label">원/달러 환율 (USDKRW)</div>
      <div class="tradingview-widget-container">
        <div class="tradingview-widget-container__widget"></div>
        <script src="https://s3.tradingview.com/external-embedding/embed-widget-symbol-overview.js" async>
        {
          "symbols": [
            [
              "FX_IDC:USDKRW|1D"
            ]
          ],
          "chartOnly": false,
          "width": "100%",
          "height": "260",
          "locale": "kr",
          "colorTheme": "dark",
          "autosize": true,
          "showVolume": false,
          "showMA": false,
          "hideDateRanges": false,
          "hideMarketStatus": false,
          "hideSymbolLogo": false,
          "scalePosition": "right",
          "scaleMode": "Normal",
          "fontFamily": "Arial, sans-serif",
          "fontSize": "10",
          "noTimeScale": false,
          "valuesTracking": "1",
          "changeMode": "price-and-percent",
          "chartType": "area",
          "maLineColor": "#2962FF",
          "maLineWidth": 1,
          "maLength": 9,
          "lineWidth": 2,
          "lineType": 0,
          "dateRanges": [
            "1D|1",
            "1M|30",
            "3M|60",
            "12M|1D",
            "60M|1W",
            "ALL|1M"
          ]
        }
        </script>
      </div>
    </div>

    <div class="card">
      <div class="label">WTI 원유 (Crude Oil)</div>
      <div class="tradingview-widget-container">
        <div class="tradingview-widget-container__widget"></div>
        <script src="https://s3.tradingview.com/external-embedding/embed-widget-symbol-overview.js" async>
        {
          "symbols": [
            [
              "TVC:USOIL|1D"
            ]
          ],
          "chartOnly": false,
          "width": "100%",
          "height": "260",
          "locale": "kr",
          "colorTheme": "dark",
          "autosize": true,
          "showVolume": false,
          "showMA": false,
          "hideDateRanges": false,
          "hideMarketStatus": false,
          "hideSymbolLogo": false,
          "scalePosition": "right",
          "scaleMode": "Normal",
          "fontFamily": "Arial, sans-serif",
          "fontSize": "10",
          "noTimeScale": false,
          "valuesTracking": "1",
          "changeMode": "price-and-percent",
          "chartType": "area",
          "maLineColor": "#2962FF",
          "maLineWidth": 1,
          "maLength": 9,
          "lineWidth": 2,
          "lineType": 0,
          "dateRanges": [
            "1D|1",
            "1M|30",
            "3M|60",
            "12M|1D",
            "60M|1W",
            "ALL|1M"
          ]
        }
        </script>
      </div>
    </div>

  </div>
</body>
</html>
